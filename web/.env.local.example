# Copy to .env.local and set your Supabase project values.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Phone on Wi‑Fi: OAuth must return to your PC’s LAN address or Safari never hits the dev server (no GET /auth/callback).
# Use your real IP from ipconfig, restart `npm run dev` / run-web-subst.ps1 after changing.
# Add the SAME origin in Supabase → Authentication → URL configuration:
#   - Redirect URLs: http://192.168.x.x:3000/auth/callback
#   - Site URL: http://192.168.x.x:3000 (while testing from the phone; avoids falling back to localhost)
# NEXT_PUBLIC_AUTH_REDIRECT_ORIGIN=http://192.168.1.5:3000
