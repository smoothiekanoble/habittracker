# Copy to scripts/codex-usage.env and fill in locally.
# Do not commit the real env file.

# Supabase project URL. Either name works.
SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Service role key is used only by this local importer, never by the browser app.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Your Supabase auth.users.id. Find this in Supabase Authentication -> Users.
CODEX_USAGE_USER_ID=00000000-0000-0000-0000-000000000000

# Optional overrides.
# CODEX_USAGE_DASHBOARD_URL=https://chatgpt.com/codex/settings/usage
# CODEX_USAGE_CHROME_PROFILE_DIR=C:\Users\danie\.codex-habittracker-codex-usage-chrome
# CODEX_USAGE_CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# CODEX_USAGE_HEADLESS=0
# CODEX_USAGE_REMOTE_DEBUGGING_PORT=9333
# CODEX_HOME=C:\Users\danie\.codex
